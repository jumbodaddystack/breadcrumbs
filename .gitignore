# breadcrumbs repository .gitignore (for the tool's own repo)
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.coverage
htmlcov/
.DS_Store

# Never commit a real memory store into the tool's own repo; .project-memory/
# belongs in target projects, not here.
.project-memory/

# ...EXCEPT the evaluation fixtures, which are committed sample stores.
!fixtures/**/.project-memory/
!fixtures/**/.project-memory/**

# But never commit a packet regenerated by running `resume` on a fixture
# (it is a rebuildable projection; CI regenerates it transiently).
fixtures/**/.project-memory/generated/resume-packet.md

# ...EXCEPT fixtures 8 and 9, which commit a hand-authored packet on purpose:
#   - fixture 8 ships a deliberately-stale packet (wrong inputs_hash) so `audit`
#     drift detection has something to catch;
#   - fixture 9 ships an accurate packet as the CLI-less cloud-fallback artifact.
!fixtures/fixture-08-packet-stale/.project-memory/generated/resume-packet.md
!fixtures/fixture-09-cloud-fallback/.project-memory/generated/resume-packet.md
